.git/
.gitignore
.gitattributes

# Docs / misc
README.md
HELP.md

# Logs & local runtime files
*.log
logs/

# Docker files themselves (not needed inside the build context)
Dockerfile
.dockerignore

# OS files
.DS_Store
Thumbs.db